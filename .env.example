# ═══════════════════════════════════════════════════
# Tempo 环境变量配置
# ═══════════════════════════════════════════════════
#
# 本文件分两部分：
#   A. Flutter 客户端配置 → 写入项目根目录 .env（gitignore）
#   B. Supabase Edge Function 配置 → 通过 supabase secrets set 部署
#
# 复制本文件为 .env 后填入 A 部分；B 部分用 CLI 设置。
# ═══════════════════════════════════════════════════


# ═══════════════════════════════════════════════════
# A. Flutter 客户端（写入 .env）
# ═══════════════════════════════════════════════════

# ── Supabase 项目 ──
# 从 Supabase Dashboard → Settings → API 获取
SUPABASE_URL=https://uvgxdmmyyujfvrvfrpsj.supabase.co
SUPABASE_ANON_KEY=

# ── Edge Function 端点 ──
# Dashboard → Edge Functions → 对应函数 → Invocation URL
TEMPO_PARSE_TASK_ENDPOINT=https://uvgxdmmyyujfvrvfrpsj.supabase.co/functions/v1/parse-task
TEMPO_SIYUAN_PAIRING_ENDPOINT=https://uvgxdmmyyujfvrvfrpsj.supabase.co/functions/v1/siyuan-pairing


# ═══════════════════════════════════════════════════
# B. Supabase Edge Function Secrets（通过 CLI 设置）
# ═══════════════════════════════════════════════════
#
# 以下变量不写入 .env，而是通过 supabase secrets set 部署到云端。
# 示例命令见各节注释。
#
# ───────────────────────────────────────────────────
# B1. 豆包大模型 LLM（文本 NLP 解析）
# ───────────────────────────────────────────────────
# 开通步骤：
#   1. 注册火山引擎账号 → 实名认证
#   2. 控制台搜索"方舟" → 模型市场开通模型（余额 ≥200 元）
#   3. 模型推理 → 创建接入点 → 复制 ep-xxxx ID
#   4. 控制台侧边栏 → API 密钥管理 → 创建 API Key
#
# supabase secrets set \
#   DOUBAO_API_KEY=你的API密钥 \
#   DOUBAO_MODEL=ep-xxxxxxxx-xxxxx
#
DOUBAO_API_KEY=
# 方舟接入点 ID（ep- 开头），从模型推理页面创建后复制
DOUBAO_MODEL=
# 可选，默认 https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# ───────────────────────────────────────────────────
# B2. 火山引擎 ASR（录音文件识别标准版）
# ───────────────────────────────────────────────────
# 开通步骤：
#   1. 火山引擎控制台搜索"语音技术" → 开通"大模型录音文件识别标准版"
#   2. 新版控制台 → 创建应用 → 获取 API Key（即 X-Api-Key）
#   3. 资源 ID 已在代码中硬编码为 volc.bigasr.auc（标准版 1.0）
#
# 工作原理（无需额外配置）：
#   Edge Function 自动将音频上传到 Supabase Storage 私有 bucket（tempo-audio），
#   生成 signed URL 提交给火山引擎 ASR，轮询结果后自动清理临时文件。
#   SUPABASE_URL 和 SUPABASE_SERVICE_ROLE_KEY 由 Edge Function 环境自动注入。
#
# supabase secrets set VOLCENGINE_ASR_API_KEY=你的APIKey
#
VOLCENGINE_ASR_API_KEY=

# ───────────────────────────────────────────────────
# B3. 开发调试
# ───────────────────────────────────────────────────
# 设为 "true" 时 Edge Function 返回固定 mock 响应，
# 无需真实 API 密钥即可调试前端流程。
#
# supabase secrets set VOICE_TASK_MOCK=true
#
VOICE_TASK_MOCK=

# ───────────────────────────────────────────────────
# 一键部署所有 Secrets 示例（复制后填入真实值）：
# ───────────────────────────────────────────────────
# supabase secrets set \
#   DOUBAO_API_KEY= \
#   DOUBAO_MODEL= \
#   VOLCENGINE_ASR_API_KEY=
